# Browser behavior
HEADLESS=false
BROWSER_SLOW_MO=250
ACTION_DELAY_MS=700
KEYBOARD_DELAY_MS=35
DEFAULT_TIMEOUT_MS=15000
SCREENSHOT_DIR=screenshots
LOG_DIR=logs

# Gemini planner
# Put your real key in .env only. Do not commit or paste it into source code.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Assignment inputs
ASSIGNMENT_NAME=Kabee Student
ASSIGNMENT_DESCRIPTION=Steps: open login, tap button; expected dashboard; actual nothing happens on mobile.

# Generic search defaults
SEARCH_ENGINE=google
SEARCH_QUERY=Playwright browser automation TypeScript
YOUTUBE_QUERY=TypeScript Playwright automation tutorial